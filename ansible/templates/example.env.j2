# Example Jinja2 template — mirrors .env.j2 with safe placeholder values.
# Useful as a reference for what variables the real template expects.

BACKEND_PORT={{ backend_port | default(3000) }}
FRONTEND_PORT={{ frontend_port | default(8080) }}
NODE_ENV={{ node_env | default('production') }}
MOCK_DATA_ON={{ mock_data_on | default('false') }}
MULTI_TENANCY_ENABLED={{ multi_tenancy_enabled | default('false') }}
HOST={{ host | default('localhost') }}
FRONTEND_URL={{ frontend_url | default('http://localhost:8082') }}

# Database
DB_HOST={{ db_host | default('postgresdb') }}
DB_PORT={{ db_port | default(5432) }}
DB_NAME={{ db_name | default('verifywise') }}
DB_USER={{ db_user | default('verifywise') }}
DB_PASSWORD={{ db_password | default('REPLACE_ME_RANDOM_24_CHARS') }}

# Super-admin
SUPERADMIN_EMAIL={{ superadmin_email | default('admin@verifywise.com') }}
SUPERADMIN_PASSWORD={{ superadmin_password | default('REPLACE_ME_RANDOM_20_CHARS') }}

# Secrets
JWT_SECRET={{ jwt_secret | default('REPLACE_ME_RANDOM_64_HEX') }}
REFRESH_TOKEN_SECRET={{ refresh_token_secret | default('REPLACE_ME_RANDOM_64_HEX') }}
ENCRYPTION_KEY={{ encryption_key | default('REPLACE_ME_RANDOM_32_CHARS') }}
AI_GATEWAY_INTERNAL_KEY={{ ai_gateway_internal_key | default('REPLACE_ME_RANDOM_32_CHARS') }}

# Email (Resend)
EMAIL_PROVIDER=resend
EMAIL_ID=noreply@company.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
