{
  "name": "verifywise",
  "version": "1.7.0",
  "main": "index.js",
  "scripts": {
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "build": "tsc",
    "start": "npm run migrate-db && node dist/index.js",
    "postbuild": "node scripts/copyFiles.js",
    "postinstall": "patch-package",
    "migrate-db": "npx sequelize db:migrate --debug",
    "worker": "node dist/jobs/worker.js",
    "watch": "tsc-watch --noClear --onSuccess \"npm-run-all postbuild start\"",
    "reset-db": "ts-node scripts/resetDatabase.ts",
    "generate-dbml": "node scripts/generateDbml.js",
    "migrate:shared-schema": "ts-node scripts/migrateToSharedSchema.ts",
    "i18n:extract": "node scripts/extract-i18n-keys.mjs",
    "i18n:translate": "node scripts/translate-with-glossary.mjs",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "i18n:audit:strict": "node scripts/i18n-audit.mjs --strict",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "prepare": "husky"
  },
  "author": "",
  "license": "ISC",
  "description": "",
