# ============================================================
# VerifyWise — .gitignore
# ============================================================

# -------------------- Environment & Secrets --------------------
.env
.env.*
!.env.example
!.env.*.example
*.key
*.pem
*.cert
*.p12
*.pfx
*.jks

# -------------------- Dependencies --------------------
node_modules/
.pnp/
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/install-state.gz

# Python
venv/
.venv/
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
*.egg

# -------------------- Build Outputs --------------------
Clients/dist/
Servers/dist/
Servers/build/
AIGateway/dist/
EvalServer/dist/
*.tsbuildinfo

# -------------------- Logs --------------------
*.log
logs/
express.log
fastapi.log
react.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -------------------- OS --------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
._*

# -------------------- IDE / Editor --------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -------------------- Claude Code / AI Tooling --------------------
.claude/launch.json
.claude/settings.local.json
.claude/worktrees/
.claude/todos/
.claude/tasks/
.claude/teams/
.claude/scheduled-tasks/
.omc/

# AI agent temp files
agent.md
agent-output.md
agent-plan.md
plan.md
.kombai

# -------------------- Docker --------------------
docker-compose.override.yml
*.override.yml

# -------------------- Database --------------------
.db_initialized
*.sqlite
*.sqlite3
*.db
.history

# -------------------- Uploads & Generated --------------------
EvaluationModule/data/uploads/*
!EvaluationModule/data/uploads/.gitkeep
videos/
screenshots/
.webreel/
pdf-templates/

# -------------------- Kubernetes Secrets --------------------
kubernetes/*/secrets.env
kubernetes/*/secrets.yaml

# -------------------- Gateway Data --------------------
Gateway/data/config.json
Gateway/data/config.json.bak

# -------------------- Test & Coverage --------------------
coverage/
.nyc_output/
*.lcov
.pytest_cache/
htmlcov/

# -------------------- Misc --------------------
nul
*.tgz
*.tar.gz
*.zip
