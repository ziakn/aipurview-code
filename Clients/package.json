  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev:vite": "vite --host",
    "nginx": "sudo nginx -c ./nginx.conf -g 'daemon off;'",
    "dev": "concurrently \"npm run dev:vite\" \"npm run nginx\"",
    "build": "node scripts/build.js",
    "build-dev": "vite build",
    "build:original": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "preview": "vite preview",
    "test": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "analyze": "npx vite-bundle-visualizer",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "i18n:audit:strict": "node scripts/i18n-audit.mjs --strict"
  },
